# Django Settings
SECRET_KEY=django-insecure-change-this-in-production-12345
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,fleet-backend.onrender.com

# Database Configuration (Render Managed PostgreSQL or Local PostgreSQL)
DATABASE_URL=postgres://fleet_user:fleet_password@localhost:5432/fleet_db

# Redis & Celery Config
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Cloud Storage Configuration (Optional, Fallback to local files if empty)
CLOUDINARY_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# OCR Provider Settings (Use 'mock', 'google', or 'aws')
OCR_PROVIDER=mock
GOOGLE_VISION_API_KEY=
AWS_TEXTRACT_REGION_NAME=us-east-1

# JWT Settings
JWT_SECRET_KEY=jwt-secret-key-change-this-in-production-54321
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# Admin / Seed Data
SUPERADMIN_EMAIL=admin@fleetmanage.com
SUPERADMIN_PASSWORD=adminpassword123
